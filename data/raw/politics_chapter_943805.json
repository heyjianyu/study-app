:null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["C"],"simExamScore":null,"sonExer":[],"answerType":"单选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326260,"title":"社会主义改造基本完成后，国家政治生活的主题是（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"探索本国建设社会主义的道路","b":"不断解决仍然存在的敌我矛盾，同时正确处理人民内部矛盾","c":"正确处理人民内部矛盾","d":"集中力量解决人民对于建立先进的工业国的要求同落后的农业国现实之间的矛盾","e":null,"f":null,"g":null,"h":null,"rightKey":"C","keyType":"单选","analyze":"毛泽东强调，关于正确处理人民内部矛盾的问题是社会主义国家政治生活的主题。这一论断的根本着眼点，在于调动一切积极因素，团结一切可以团结的力量，把全党的注意力转移到社会主义建设上来。故C项符合题意。A、B、D三项均为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13954,"correctTimesAmount":6479,"accuracyAmount":46.4,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":5,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["C"],"simExamScore":null,"sonExer":[],"answerType":"单选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326261,"title":"中共八大关于政治报告的决议指出当时国内的主要矛盾是（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"无产阶级同资产阶级、社会主义同资本主义这两个阶级、两条道路的矛盾","b":"人民对建立先进的工业国的要求同落后的农业国的现实之间的矛盾，人民对于经济文化迅速发展的需要同当前经济文化不能满足人民需要的状况之间的矛盾","c":"生产关系和生产力之间、经济基础和上层建筑之间的矛盾","d":"中华民族同帝国主义国家特别是同美帝国主义的矛盾","e":null,"f":null,"g":null,"h":null,"rightKey":"B","keyType":"单选","analyze":"关于我国社会的主要矛盾和根本任务，党的八大正确分析了社会主义改造完成后我国社会主要矛盾的变化，指出：社会主义制度在我国已经基本上建立起来了。我国国内的主要矛盾，已经是人民对于建立先进的工业国的要求同落后的农业国的现实之间的矛盾，已经是人民对于经济文化迅速发展的需要同当前的经济文化不能满足人民需要状况之间的矛盾。故B项符合题意。A、C、D三项均为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13894,"correctTimesAmount":10118,"accuracyAmount":72.8,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":6,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["B"],"simExamScore":null,"sonExer":[],"answerType":"单选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326262,"title":"毛泽东第一次系统地阐述社会主义社会矛盾问题的著作是（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"《论十大关系》","b":"《关于正确处理人民内部矛盾的问题》","c":"《矛盾论》","d":"《论人民民主专政》","e":null,"f":null,"g":null,"h":null,"rightKey":"B","keyType":"单选","analyze":"1957年2月，毛泽东在扩大的最高国务会议上发表《关于正确处理人民内部矛盾的问题的报告》，系统论述了社会主义社会矛盾的理论。故B项符合题意。A、C、D三项均为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13956,"correctTimesAmount":9390,"accuracyAmount":67.3,"reviewExerG