:null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":16,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["A"],"simExamScore":null,"sonExer":[],"answerType":"单选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326257,"title":"20世纪50年代中期，反映以毛泽东为代表的中国共产党人探索中国自己的社会主义建设道路取得的理论成果的有（ ）。","courseID":"H011901","catID":943806,"optNum":4,"a":"毛泽东的《论十大关系》","b":"毛泽东的《关于正确处理人民内部矛盾的问题》","c":"毛泽东的《论人民民主专政》","d":"毛泽东的《井冈山的斗争》","e":null,"f":null,"g":null,"h":null,"rightKey":"AB","keyType":"多选","analyze":"A项《论十大关系》是毛泽东在1956年4月和5月先后在政治局扩大会议和最高国务会议上作的报告，初步总结了我国社会主义建设的经验，明确提出了以苏为鉴，独立自主地探索适合中国国情的社会主义建设道路。B项毛泽东1957年2月在扩大的最高国务会议上所作的《如何处理人民内部的矛盾》的讲话（讲话稿经补充修改后，以《关于正确处理人民内部矛盾的问题》为题，在《人民日报》公开发表）系统论述了社会主义社会矛盾的理论。故A、B两项符合题意。C项《论人民民主专政》在毛泽东在1949年6月30日为庆祝中国共产党成立二十八周年而写的一篇论文。D项《井冈山的斗争》是毛泽东思想初步形成的著作。故CD两项为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13828,"correctTimesAmount":6543,"accuracyAmount":47.3,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":0.0,"newKeyType":2,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":17,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["AB"],"simExamScore":null,"sonExer":[],"answerType":"多选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326258,"title":"1957年2月，毛泽东在扩大的最高国务会议上发表《关于正确处理人民内部矛盾的问题》的讲话，系统论证了社会主义社会矛盾的理论。毛泽东指出（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"矛盾是普遍存在的，社会主义社会同样充满着矛盾","b":"社会主义社会的基本矛盾仍然是生产关系和生产力之间、上层建筑和经济基础之前的矛盾，它同旧社会的基本矛盾性质是一样的","c":"社会主义社会的矛盾反映在政治上可以划分为敌我矛盾和人民内部矛盾这两类性质完全不同的矛盾，正确处理人民内部矛盾是国家政治生活的主题","d":"社会主义社会的矛盾可以通过社会主义制度本身得到解决","e":null,"f":null,"g":null,"h":null,"rightKey":"ACD","keyType":"多选","analyze":"社会主义社会的基本矛盾与以往的社会的基本矛盾具有不同的性质和情况。以往社会的基本矛盾，生产力和生产关系之间存在着一定程度的对抗和冲突，而社会主义社会的基本矛盾是在生产力和生产关系基本适应、上层建筑和经济基础基本适应的条件下的矛盾，是在人民根本利益一致基础上的矛盾。故B项表述错误。故A、C、D三项符合题意。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13711,"correctTimesAmount":5061,"accuracyAmount":36.9,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":0.0,"newKeyType":2,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":18,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["ACD"],"simExamScore":null,"sonExer":[],"answerType":"多选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326259,"title":"毛泽东提出探索马克思主义同中国实际即社会主义建设实际的“第二次结合”，说明中国共产党（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"开始探索适合中国特点的社会主义建设道路","b":"开始摆脱单一的苏联模式","c":"开始重新认识“什么是社会主义，怎样建设社会主义”","d":"开始改革开放的事业","e":null,"f":null,"g":null,"h":null,"rightKey":"AB","keyType":"多选","analyze":"新中国成立初期，我国主要是学习苏联的经验，这在当时是必要的，也取得了一定的成效。但是，照搬照抄苏联经验不符合中国的国情，仍需要实现马克思主义与中国实际的第二系结合，积极探索适合中国特点的社会主义建设道路。因此，毛泽东提出探索马克思主义同中国实际即社会主义建设实际的第二次结合，说明中国共产党开始探索适合中国特点的社会主义建设道路；开始摆脱单一的苏联模式。故A、B两项符合题意。C、D为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13783,"correctTimesAmount":4713,"accuracyAmount":34.2,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":0.0,"newKeyType":2,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":19,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["AB"],"simExamScore":null,"sonExer":[],"answerType":"多选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326271,"title":"陈云在中共“八大”上提出的“三个主体，三个补充”的重要思想是指（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"在工商业经营方面，国家经营和集体经营为主补充一定的个体经营","b":"在生产计划方面，计划生产为主补充一定的自由生产","c":"在市场方面，国家市场为主补充一定范围的自由市场","d":"在分配方面，以按劳分配为主补充一定的其他分配形式","e":null,"f":null,"g":null,"h":null,"rightKey":"ABC","keyType":"多选","analyze":"解析：走中国工业化道路，必须调整和完善所有制结构。陈云提出了“三个主体，三个补充”的设想，即在工商业经营方面，国家经济和集体经济是工商业的主体，一定数量的个体经济是国家经济和集体经济的补充；在生产计划方面，计划生产是工农业生产的主体，按照市场变化在国家计划许可范围内的自由生产是计划生产的补充；在社会主义的统一市场里，国家市场是它的主体，一定范围内的国家领导的自由市场是国家市场的补充。故A、B、C三项符合题意。D项为干扰选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13452,"correctTimesAmount":6163,"accuracyAmount":45.8,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":0.0,"newKeyType":2,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":20,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["ABC"],"simExamScore":null,"sonExer":[],"answerType":"多选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326273,"title":"党领导人民探索社会主义建设道路，经历艰辛和曲折，在理论上和实践上取得了一系列重要成果。社会主义建设道路初步探索的意义有（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"巩固和发展了我国的社会主义制度","b":"为开创中国特色社会主义提供了宝贵经验、理论准备、物质基础","c":"丰富了科学社会主义的理论和实践","d":"促进了世界社会主义发展","e":null,"f":null,"g":null,"h":null,"rightKey":"ABCD","keyType":"多选","analyze":"党领导人民探索社会主义建设道路，历经艰辛和曲折，在理论和实践上取得了一系列重要成果。这些成果对于巩固我国社会主义制度，开创和发展中国特色社会主义，促进世界社会主义的发展，具有重要意义：巩固和发展了我国的社会主义制度。为开创中国特色社会主义提供了宝贵经验、理论准备、物质基础。丰富了科学社会主义的理论和实践，为其他国家的社会主义建设提供了经验和借鉴。故A、B、C、D四项均符合题意。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13490,"correctTimesAmount":7710,"accuracyAmount":57.2,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":0.0,"newKeyType":2,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":21,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["ABCD"],"simExamScore":null,"sonExer":[],"answerType":"多选","exerNum":null,"prname":"第二部分 毛泽东思想和中国特色社会主义理论体系概论>第五章 社会主义建设道路初步探索的理论成果"},{"exerID":4326274,"title":"在我国社会主义改造基本完成、开始全面建设社会主义的时候，毛泽东就向全党提出，要探索马克思主义同中国实际的“第二次结合”，走适合中国特点的社会主义建设道路。以下对党在社会主义建设道路上的初步探索所取得的成果评价正确的有（ ）","courseID":"H011901","catID":943806,"optNum":4,"a":"成为邓小平提出中国特色社会主义理论的前提和条件","b":"为实现马克思主义基本原理同中国实际相结合的第二次飞跃提供基础","c":"为改革开放伟大事业的进行提供了宝贵经验","d":"提出了社会主义本质的科学论断","e":null,"f":null,"g":null,"h":null,"rightKey":"ABC","keyType":"多选","analyze":"党在社会主义建设道路上的初步探索所取得的成果，是邓小平提出中国特色社会主义理论的前提和条件，为实现马克思主义基本原理同中国实际相结合的第二次飞跃提供基础，也为改革开放伟大事业的进行提供了宝贵经验。社会主义本质的科学论断，是邓小平在改革开放以后提出来的，并不是党在建设社会主义道路上初步探索的成果。故A、B、C三项符合题意。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":13550,"correctTimesAmount":5966,"accuracyAmount":44.0,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"create