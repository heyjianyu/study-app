{"code":200,"message":"成功","flag":true,"data":{"prId":54702765,"scoringMethod":1,"name":null,"exerList":[{"exerID":4326078,"title":"“求木之长者，必固其根本；欲流之远者，必浚其泉源。”这一观点给我们的哲学启示是（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"事物之间都是有联系的","b":"意识制约着事物的联系","c":"事物的联系具有多样性","d":"事物各要素间相互联系","e":null,"f":null,"g":null,"h":null,"rightKey":"D","keyType":"单选","analyze":"根本是树木的一部分、泉源是河流的一部分，根本影响木之长、泉源影响河流之远，体现了事物内部各个部分、要素之间是相互联系的，D选项说法正确；题干强调事物要素间的联系，不是事物之间的联系，事物间的联系是具体的有条件的，并非任何事物之间都有联系，A选项观点错误；事物联系具有客观性，B选项说法错误；题干没有强调联系的多样性，C选项不符合题意。本题选择D选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40358,"correctTimesAmount":21419,"accuracyAmount":53.1,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":1,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["D"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326079,"title":"下列符合联系客观性的是（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"左眼跳财、右眼跳灾","b":"喜鹊报喜、乌鸦报丧","c":"买楼要买七楼而不能买八楼，因为“七上八下”","d":"早霞不出门、晚霞行千里","e":null,"f":null,"g":null,"h":null,"rightKey":"D","keyType":"单选","analyze":"ABC均属于主观臆造的联系，这些事物之间没有必然联系，违背了联系的客观性。符合联系客观性的只有D选项。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":39834,"correctTimesAmount":31780,"accuracyAmount":79.8,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":2,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["D"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326080,"title":"“塘基种桑、桑叶养蚕、蚕沙喂鱼、鱼粪肥塘、塘泥壅桑”，浙江湖州的这一“桑基鱼塘系统”凝结着江南水乡千百年来的劳动智慧，被联合国粮农组织在第五届全球重要农业文化遗产国际论坛上认定为新增遗产。这一古老的中国农业智慧体现的哲理主要是（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"事物是普遍联系的","b":"“两点论”与“重点论”相结合","c":"绝对运动中包含着相对静止","d":"原因与结果互相渗透","e":null,"f":null,"g":null,"h":null,"rightKey":"A","keyType":"单选","analyze":"联系具有普遍性。事物联系的普遍性有三层含义：其一，任何事物内部的不同部分和要是相互联系的，即任何事物都具有内在的结构性。其二，任何事物都不能孤立存在，都同其他事物处于一定的相互联系之中。其三，整个世界是相互联系的统一整体，每事物都是世界普遍联系中的一个成分或环节，并通过它表现出联系的普遍性。“桑基鱼塘系统”正是充分认识和利用了事物之间的联系。A正确。B、C、D不符合题意。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40395,"correctTimesAmount":27740,"accuracyAmount":68.7,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":3,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["A"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326081,"title":"按照大数据画像，婴儿尿布可能会和奶粉、玩具等商品相关联，啤酒的消费者可能会同时选购花生米、薯片等零食。而国外一家零售商依据小数据的分析显示，男性顾客在购买婴儿尿布时，常会顺便搭配几瓶啤酒来犒劳自己，于是商店尝试推出了将啤酒和尿布摆在一起的促销手段，竟然取得了成功。以上材料说明（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"主要矛盾贯穿事物发展过程始终并规定事物及其过程的性质","b":"矛盾的次要方面也可以起主导作用","c":"事物之间有其固有的客观联系","d":"事物的普遍联系是通过数据这个中介来实现的","e":null,"f":null,"g":null,"h":null,"rightKey":"C","keyType":"单选","analyze":"联系具有客观性。世界上没有孤立存在的事物，每一种事物都是在与其他事物的联系之中存在的，事物的联系是事物本身所固有的，不是主观臆想的。联系的客观性要求我们从客观事物本身固有的联系出发去认识事物。故选C。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40365,"correctTimesAmount":23098,"accuracyAmount":57.2,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":4,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["C"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326082,"title":"“山川异域，风月同天；青山一道，共担风雨。”这些在新冠肺炎疫情全球大流行中广为人知的格言提醒着人们，病毒没有国界，疫情不分种族。病毒是全人类共同的敌人，没有哪个国家、哪个人能在病毒面前独善其身，人类是休戚与共的命运共同体。从哲学上讲，“人类是休戚与共的命运共同体”是因为（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"统一的全人类国家是社会发展的终极形态","b":"任何事物之间都存在着直接联系","c":"在和谐的前提下矛盾可以体现为绝对的同一","d":"世界是普遍联系的有机整体","e":null,"f":null,"g":null,"h":null,"rightKey":"D","keyType":"单选","analyze":"任何事物都不能孤立存在，都同其他事物处于一定的相互联系之中。整个世界是相互联系的统一整体，每一事物都是世界普遍联系中的一个成分或环节，并通过它体现出联系的普遍性。D正确。国家是一个历史范畴，有它的产生、发展和消亡。在共产主义社会，阶级和国家都将消亡。A错误。联系具有多样性。世界上的事物是多样的，因而事物的联系也是多样的。事物联系的主要方式有：内部联系与外部联系、直接联系与间接联系、必然联系与偶然联系、本质联系与非本质联系等。不同的联系构成事物内部和事物之间的存在状态和发展趋势。直接联系并不是唯一的联系方式。B错误。和谐是矛盾的一种特殊表现形式，体现着矛盾双方的相互依存、相互促进、共同发展，和谐并不意味着矛盾的绝对同一。和谐是相对的、有条件的，只有在矛盾双方处于平衡、协调、合作的情况下，事物才展现出和谐状态。C错误。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40441,"correctTimesAmount":27523,"accuracyAmount":68.1,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":5,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["D"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326083,"title":"“开车时打开空调油耗会增加”，这是很多开车人坚信的“真理”。其实，这一理论并不完全正确，有关专家表示，在气温适宜、时速小于60公里时，通过开窗通风会比打开空调更省油，但当时速高于80公里时，开窗会增加车辆风阻，此时关窗开着空调反而更省油。这反映了（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"联系具有条件性","b":"联系具有普遍性","c":"联系具有客观性","d":"联系具有多样性","e":null,"f":null,"g":null,"h":null,"rightKey":"A","keyType":"单选","analyze":"本题考查的知识点是联系的条件性。联系具有条件性。条件是对事物存在和发展发生作用的诸要素的总和。其一，条件对事物发展和人的活动具有支持或制约作用；其二，条件是可以改变的，人们经过努力可以创造出事物发展所需要的条件；其三，改变和创造条件不是任意的，必须尊重事物发展的客观规律。题干中，在不同的条件下，开窗通风会带来不同的油耗，这体现出联系具有条件性。因此，本题的正确答案是A。选项B、C、D都是联系的特征，但不符合题意。因此，排除。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40460,"correctTimesAmount":24310,"accuracyAmount":60.1,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":6,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["A"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326084,"title":"下列选项体现发展的观点的是（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"随着互联网的发展，出现了网络算命等新的形式","b":"全球变暖，极地冰盖融化，海平面上升","c":"经济全球化进入新时代，出现了以美国为代表的新的逆全球化思潮","d":"“两山论”代替“先污染、后治理”的思想","e":null,"f":null,"g":null,"h":null,"rightKey":"D","keyType":"单选","analyze":"发展的实质是事物的前进和上升，是新事物的产生和旧事物的灭亡。选项中只有D选项才是新事物战胜了旧事物。ABC只能算是变化但不是发展。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40319,"correctTimesAmount":24764,"accuracyAmount":61.4,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":7,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["D"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326085,"title":"据统计，我国不少公共场所儿童免票标准都在1.2米至1.3米之间。但由于营养状况和成长环境的改善，儿童平均身高早已达到甚至超过这一标准。目前，已有城市开始实行按年龄和身高免票的双轨制，结合实际情况保障好儿童权益。以上材料说明（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"事物本质的暴露需要一个过程","b":"物质形态的多样性只有在物质的绝对运动中才能显示出来","c":"偶然是必然的表现形式和补充","d":"事物处在变化发展的过程中","e":null,"f":null,"g":null,"h":null,"rightKey":"D","keyType":"单选","analyze":"事物的相互联系包含着事物的相互作用，而相互作用必然导致事物的运动、变化和发展。事物之间相互作用的结果，使事物原有的状态或性质发生程度不同的变化，概括一切形式的变化就是运动，运动变化的基本趋势是发展。事物的发展是一个过程。一切事物只有经过一定的过程才能实现自身的发展。坚持事物发展是过程的思想，就要用历史的眼光看问题，把一切事物如实地看作是变化、发展的过程，既要了解它们的过去、观察它们的现在，又要预见它们的未来。D正确、A、B、C不符合题意（材料指出儿童平均身高已增长是一种变化，并没有强调不同的儿童身高不同）。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40545,"correctTimesAmount":28630,"accuracyAmount":70.6,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":8,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["D"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326086,"title":"人体细胞的新陈代谢周期平均为3个月。由于不同细胞代谢的时间和间隔不同，所以将一身细胞全部换掉需要7年。其中，红细胞的平均寿命为120天，肝细胞的寿命约为150天，而看似终生不变的人体骨架约每6年也会重新更换一次。人体细胞的新陈代谢说明了（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"物质存在的时空是无限的、相对的","b":"发展的实质是新事物的产生和旧事物的灭亡","c":"事物发展变化只有连续性没有间断性","d":"事物永恒变化的基本趋势是运动","e":null,"f":null,"g":null,"h":null,"rightKey":"B","keyType":"单选","analyze":"本题考查的知识点是发展的观点。发展是前进的、上升的运动，发展的实质是新事物的产生和旧事物的灭亡。根据材料“新陈代谢”及其过程，我们可以看出细胞的新陈代谢都是新细胞不断取代旧细胞的过程。因此，正确答案是B。选项A表述错误，具体物质形态的时空是有限的，整个物质世界的时空是无限的；物质运动时间和空间的客观实在性是绝对的，物质运动时间和空间的具体特性是相对的。因此，排除。选项C表述错误，事物发展是连续性与间断性的统一，连续性体现了事物发展过程之中的量变，间断性体现了事物量变过程中的质变。因此，排除。选项D表述错误，事物运动变化的基本趋势是发展。因此，排除。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40404,"correctTimesAmount":29974,"accuracyAmount":74.2,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":9,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["B"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326087,"title":"事物的发展是一个过程，只有经过一定的过程，事物才能实现自身的发展。恩格斯指出，“世界不是既成事物的集合体，而是过程的集合体。”下列与之表达意思相近的是（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"现存的事物都是合理的","b":"物质第一性，意识第二性","c":"任何事物都应从其暂时性的角度去理解","d":"凡是现存的都是永恒的","e":null,"f":null,"g":null,"h":null,"rightKey":"C","keyType":"单选","analyze":"本题考查的知识点是发展的过程论。事物的发展是一个过程，只有经过一定的过程，事物才能实现自身的发展。事物发展的过程，从形式上看，是事物在时间上的持续性和空间上的广延性的交替；从内容上看，是事物在运动形式、形态、结构、功能和关系上的更新。事物是不断运动变化的，从其暂时性来理解，就是把任何事物都当作一个过程来看待。因此，本题的正确答案是C。选项A表述错误，这里的“理”指的是绝对理念，现存的事物是不断发展着的，因此，排除。选项B.“物质第一性，意识第二性”是物质和意识的辩证关系，不符合题意，因此，排除。选项D表述错误，现存的事物都是不断运动变化的，永恒不变的事物是不存在的，因此，排除。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40281,"correctTimesAmount":27025,"accuracyAmount":67.1,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":10,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["C"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326088,"title":"西方有一句名言：“生命中最伟大的光辉不在于永不坠落，而是坠落后总能再度升起。”这告诉我们（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"人生就是在失败和成功中反复","b":"事物的发展是前进性与曲折性的统一","c":"要成功必须经历失败","d":"事物发展是一个周而复始的过程","e":null,"f":null,"g":null,"h":null,"rightKey":"B","keyType":"单选","analyze":"本题考查事物发展的前进性和曲折性。题干强调生命的伟大不在于永不坠落，而在于坠落后总能再度升起，正说明事物的发展是前进性和曲折性的统一。因此，选项B正确。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40467,"correctTimesAmount":28565,"accuracyAmount":70.6,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":11,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["B"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326089,"title":"“君子以思患而预防之”，有备才能无患。十八大以来，习近平总书记十分重视底线思维，凡事不能超越底线。如法律底线、政策底线、利益底线、道德底线等，一旦突破这些底线，就会出现无法接受的坏结果。从哲学的角度分析，底线是指（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"联系的条件性","b":"度的关节点","c":"主要矛盾","d":"事物发展的连续性","e":null,"f":null,"g":null,"h":null,"rightKey":"B","keyType":"单选","analyze":"度是事物保持自己质的稳定性的数量界限，即事物的范围、幅度和限度。度的两端叫关节点，也叫临界点。超出度的范围，此物就转化为他物。所谓底线，就是不可逾越的界限，是事物发生质变的临界点。底线思维是我们在认识世界和改造世界的过程中，根据我们的需要和客观的条件，划清并坚守底线，尽力化解风险，避免最坏结果，同时争取实现最大期望值的一种积极的思维。B正确。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40391,"correctTimesAmount":26789,"accuracyAmount":66.3,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":null,"jcontent":null,"agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":12,"myCollectionId":0,"exerEcontent":null,"exerJcontent":null,"userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["B"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326090,"title":"事物的质是由（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"它本身所固有的普遍矛盾所决定的","b":"它本身所固有的主要矛盾的主要方面所决定的","c":"它本身所固有的特殊矛盾所决定的","d":"它本身所固有的外部矛盾所决定的","e":"","f":"","g":"","h":"","rightKey":"B","keyType":"单选","analyze":"事物的性质是由事物的主要矛盾的主要方面所决定，故B选项符合题意。","matRef":"","diffCoeff":1,"freqCoeff":1,"exerType":"历年试题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40247,"correctTimesAmount":29430,"accuracyAmount":73.1,"reviewExerGroupID":0,"exerGroupId":0,"subTitle":null,"econtent":"","jcontent":"","agencyId":0,"isAudit":1,"adminId":0,"auditId":31106,"auditTime":null,"createTime":"2024-06-25T06:23:15.000+00:00","sourceExerId":null,"scoreRules":null,"scoreLess":null,"newKeyType":1,"isUnorderedMate":0,"isMaterial":0,"wrongSource":null,"score":null,"typeName":null,"isFinishs":0,"accuracy":null,"progressPercentage":null,"questionNumber":null,"questionAllNumber":null,"starCount":0,"sourceType":null,"collectionType":null,"cstId":null,"userKey":null,"wrongSum":null,"myCollectionld":null,"linkName":null,"simNum":null,"simScore":null,"answerTypeId":null,"index":13,"myCollectionId":0,"exerEcontent":"","exerJcontent":"","userKeyImg1":null,"userKeyImg2":null,"userKeyImg3":null,"isCorrect":null,"rightKeyList":["B"],"simExamScore":null,"sonExer":[],"answerType":"单选","prname":"第一部分 马克思主义哲学原理>第三章 事物的普遍联系和变化发展","exerNum":null},{"exerID":4326091,"title":"近年来，互联网的迅猛发展与普遍接入，使大量数据的获取、聚集、存储、传输、处理、分析等变得越来越便捷，大数据分析成为可能。大数据分析通过对各种不同的联系分别地、具体地加以研究，从海量的数据中找到隐藏的关联，从而帮助各行各业的人们做出正确的决定。这表明（ ）。","courseID":"H011901","catID":943789,"optNum":4,"a":"世界是相互联系的统一整体","b":"联系具有多样性","c":"事物之间的联系都是人为的","d":"数据是世界普遍联系的基础","e":null,"f":null,"g":null,"h":null,"rightKey":"AB","keyType":"多选","analyze":"联系和发展的观点是唯物辩证法的总观点和总特征。联系是指事物内部各要素之间和事物之间相互影响、相互制约和相互作用的关系。联系具有客观性、普遍性、多样性和条件性。事物的联系是事物本身所固有的，不是主观臆想的。整个世界是相互联系的统一整体，事物的普遍联系是通过“中介”来实现的，是通过中间性的联系和过渡性环节而实现的。世界上的事物是多样的，事物之间的联系也是多样的，大数据分析就是要从多种多样的联系中找出对人们有价值的联系。A、B是正确选项。C否认事物联系的客观性，因而是错误的。世界普遍联系的客观基础是物质，而不是数据，D也是错误的。","matRef":null,"diffCoeff":1,"freqCoeff":1,"exerType":"章节题","source":"章节题","isValid":1,"isMultiExer":1,"multiExerID":null,"isHtmlTag":0,"pracTimesAmount":40248,"correctTimesAmount":15318,"accuracyAmount":38.1,"reviewExerGroupID":0,"exerGroupId